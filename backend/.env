# ──────────────────────────────────────────────────────────────────────────────
# ACW Assistant — Backend Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env with real secrets to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ANTHROPIC_API_KEY
# Your Anthropic API key — required for Claude Haiku call summarization.
# Get one at https://console.anthropic.com/settings/keys
# Format: sk-ant-...
ANTHROPIC_API_KEY=

# DATABASE_URL
# SQLAlchemy-compatible database connection string.
# Default uses a local SQLite file (no setup needed for local dev).
# For production on Railway, set this to a PostgreSQL URL:
#   postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./acw_summaries.db
